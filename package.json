{
  "name": "craft-apex",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:employee": "turbo build --filter=@craft-apex/employee-portal",
    "build:partner": "turbo build --filter=@craft-apex/partner-portal",
    "build:customer": "turbo build --filter=@craft-apex/customer-portal",
    "dev": "turbo dev",
    "dev:employee": "turbo dev --filter=@craft-apex/employee-portal",
    "dev:partner": "turbo dev --filter=@craft-apex/partner-portal",
    "dev:customer": "turbo dev --filter=@craft-apex/customer-portal",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.4.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "geist": "^1.7.0"
  }

}
