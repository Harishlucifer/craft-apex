{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["VITE_API_ENDPOINT", "VITE_PLATFORM"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "lint"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
